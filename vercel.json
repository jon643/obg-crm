{
  "crons": [
    {
      "path": "/api/cron/generate-blog-post",
      "schedule": "0 13 * * *"
    }
  ],
  "rewrites": [
    { "source": "/_astro/:path*", "destination": "https://obg-profit-calculator.vercel.app/_astro/:path*" },
    { "source": "/calculator", "destination": "https://obg-profit-calculator.vercel.app/calculator" },
    { "source": "/calculator/:path*", "destination": "https://obg-profit-calculator.vercel.app/calculator/:path*" },
    { "source": "/fees", "destination": "https://obg-profit-calculator.vercel.app/fees" },
    { "source": "/fees/:path*", "destination": "https://obg-profit-calculator.vercel.app/fees/:path*" },
    { "source": "/tools/:path*", "destination": "https://obg-profit-calculator.vercel.app/tools/:path*" },
    { "source": "/guide/:path*", "destination": "https://obg-profit-calculator.vercel.app/guide/:path*" },
    { "source": "/vs/:path*", "destination": "https://obg-profit-calculator.vercel.app/vs/:path*" },
    { "source": "/category", "destination": "https://obg-profit-calculator.vercel.app/category" },
    { "source": "/category/:path*", "destination": "https://obg-profit-calculator.vercel.app/category/:path*" }
  ]
}
